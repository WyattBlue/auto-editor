diff --git a/libavfilter/vf_pad.c b/libavfilter/vf_pad.c
--- a/libavfilter/vf_pad.c
+++ b/libavfilter/vf_pad.c
@@ -239,11 +239,21 @@
     int plane;

     if (s->inlink_w <= 0)
+        return NULL;
+
+    /* When s->x > 0 the per-plane data pointers would be shifted by a
+     * sub-linesize pixel amount after allocation.  Upstream SIMD output
+     * routines (e.g. the scale filter's NEON code on Windows ARM64) may
+     * fault on such non-linesize-aligned pointers.  Return NULL so the
+     * upstream filter allocates its own buffer; filter_frame will copy
+     * the data into the padded output instead, which is always safe.
+     * Vertical-only offsets (s->y) are always linesize-aligned and safe. */
+    if (s->x)
         return NULL;

     frame = ff_get_video_buffer(inlink->dst->outputs[0],
                                 w + (s->w - s->in_w),
-                                h + (s->h - s->in_h) + (s->x > 0));
+                                h + (s->h - s->in_h));

     if (!frame)
         return NULL;
